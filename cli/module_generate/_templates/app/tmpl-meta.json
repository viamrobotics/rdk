{
	"module_id": "{{ .Namespace }}:{{ .ModuleName }}",
	"visibility": "{{ .Visibility }}",
	"description": "{{ .AppName }} app",
	"models": [
		{
			"api": "rdk:component:generic",
			"model": "{{ .Namespace }}:{{ .ModuleName }}:webapp"
		}
	],
	"applications": [
		{
			"name": "{{ .AppName }}",
			"type": "{{ .AppType }}",
			"entrypoint": "dist/index.html"
		}
	],
	"entrypoint": "bin/{{ .ModuleName }}",
	"build": {
		"build": "make module.tar.gz",
		"setup": "make setup",
		"path": "module.tar.gz",
		"arch": ["linux/amd64", "linux/arm64", "darwin/arm64"]
	}
}
