FROM debian:latest

RUN apt update && DEBIAN_FRONTEND="noninteractive" apt install -y sudo

RUN useradd -m testbot
RUN echo 'testbot ALL=(ALL) NOPASSWD:ALL' >> /etc/sudoers

USER testbot

COPY etc/setup.sh /tmp/setup.sh
RUN bash /tmp/setup.sh

USER root

RUN rm -rf /home/testbot/.cache
RUN apt clean

RUN cp /home/testbot/.bashrc /home/testbot/.bash_profile /home/testbot/.viamdevrc /root/

ENTRYPOINT ["bash", "-lc"]
